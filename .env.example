# ============================================================================
#  Smart Quiz AI Hub — settings
#  Copy this file to ".env" (same folder) and edit the values you care about,
#  then run:  docker compose up --build
#  You do NOT need to touch any other file. Every line has a safe default, so
#  blanks/defaults are fine. Lines starting with # are comments.
# ============================================================================

# ── Web ─────────────────────────────────────────────────────────────────────
# The port you open in your browser (http://localhost:<APP_PORT>).
# Change this if 4200 is already used by something else.
APP_PORT=4200

# ── AI (optional) ────────────────────────────────────────────────────────────
# Leave OPENAI_API_KEY blank to run fully offline (built-in fallbacks: a local
# question generator + a non-AI similarity scorer). Paste a real key to use AI.
OPENAI_API_KEY=

# Duplicate-detection sensitivity, 0.0–1.0 (0.30 = 30%). Lower = stricter.
AI_SIMILARITY_THRESHOLD=0.30

# Use AI embeddings for similarity (auto-falls back to offline scorer on failure).
AI_EMBEDDINGS_ENABLED=true

# Advanced: lower bound used to rescale embedding similarity into 0–1.
AI_EMBEDDING_FLOOR=0.50

# ── Security ─────────────────────────────────────────────────────────────────
# Change this to a long random string for any real/shared deployment.
JWT_SECRET=${JWT_SECRET}
# How long a login stays valid, in milliseconds (86400000 = 24 hours).
JWT_EXPIRATION_MS=86400000

# ── Database (advanced) ──────────────────────────────────────────────────────
# Password for the internal database. NOTE: only applied when the database is
# first created. To change it on an existing setup, reset with:
#   docker compose down -v   (this erases existing data)
DB_PASSWORD=root
